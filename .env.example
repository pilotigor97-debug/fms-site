# --------- Multi-tenant routing ---------
# Domínio raiz onde o site institucional está hospedado.
# Em dev: localhost / em prod: opspilot.com.br ou fms-saas.vercel.app
NEXT_PUBLIC_ROOT_DOMAIN=localhost

# URL do app Flutter pra handoff de login (legacy custom token, apps nativos).
NEXT_PUBLIC_APP_URL=https://opspilot-dev.web.app

# --------- Firebase ---------
# IMPORTANTE: o site compartilha o mesmo projeto Firebase do app OpsPilot
# SaaS multi-tenant (opspilot-dev em dev, opspilot-prod em prod). O app
# Flutter está em /Users/fernandes/development/opspilot/ e é buildado
# para fms-site/public/app/ via `npm run build:flutter`.
FIREBASE_PROJECT_ID=opspilot-dev

# Web API Key — usada server-side pelo /api/auth/login (legacy handoff).
# Está em opspilot/lib/firebase_options.dart (web).
FIREBASE_WEB_API_KEY=your-web-api-key-here

# Service Account do Firebase Admin SDK — gera no Console:
# Project Settings → Service Accounts → Generate New Private Key
# Essas credenciais SÃO segredas — server-side only.
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@opspilot-dev.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...your key here...\n-----END PRIVATE KEY-----\n"

# --------- Firebase Web SDK (client-side) ---------
# Vão pro bundle do client (NEXT_PUBLIC_*). Não são segredos.
# Usados pra Firebase JS SDK no /login e /criar-conta.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyA2f8TcsgffjbDylxcyO3OEprR0JY6-Gn8
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=opspilot-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=opspilot-dev
NEXT_PUBLIC_FIREBASE_APP_ID=1:30848564493:web:9c174736b30e753783c444
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=opspilot-dev.firebasestorage.app

# --------- Sales lead form ---------
# Email pra onde os leads do botão "Falar com vendas" são enviados.
SALES_LEAD_EMAIL=vendas@opspilot.com.br
