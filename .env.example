# --------- Multi-tenant routing ---------
# Domínio raiz onde o site institucional está hospedado.
# Em dev: localhost / em prod: opspilot.com.br ou fms-saas.vercel.app
NEXT_PUBLIC_ROOT_DOMAIN=opspilot-dev.web.app

# URL do app Flutter pra redirect pós-login (handoff).
# Em prod aponta pro Firebase Hosting (mesmo Project que tem auth).
NEXT_PUBLIC_APP_URL=https://opspilot-dev.web.app

# --------- Firebase ---------
FIREBASE_PROJECT_ID=opspilot-dev

# Web API Key — usada pelo route /api/auth/login pra autenticar
# via REST do Identity Toolkit. Pega em Console → Project Settings
# → General → Web API Key. NÃO é segredo absoluto (pode ir pro
# client), mas mantemos server-side pra organização.
FIREBASE_WEB_API_KEY=your-web-api-key-here

# Service Account do Firebase Admin SDK — gera no Console:
# Project Settings → Service Accounts → Generate New Private Key
# Essas credenciais SÃO segredas — server-side only.
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@opspilot-dev.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...your key here...\n-----END PRIVATE KEY-----\n"

# --------- Sales lead form ---------
# Email pra onde os leads do botão "Falar com vendas" são enviados.
# Reutiliza a extensão firestore-send-email do projeto: enfileira
# em `mail/` collection com kind='salesLead'.
SALES_LEAD_EMAIL=vendas@opspilot.com.br
